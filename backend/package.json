{
  "name": "province-games-backend",
  "version": "1.0.0",
  "description": "Province Games — REST API + WebSocket server",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start":   "node server.js",
    "dev":     "nodemon server.js",
    "db:init": "psql $DATABASE_URL -f database/schema.sql",
    "lint":    "eslint . --ext .js"
  },
  "dependencies": {
    "cors":       "^2.8.5",
    "dotenv":     "^16.3.1",
    "express":    "^4.18.2",
    "helmet":     "^7.1.0",
    "morgan":     "^1.10.0",
    "pg":         "^8.11.3",
    "ws":         "^8.16.0"
  },
  "devDependencies": {
    "eslint":     "^8.57.0",
    "nodemon":    "^3.0.3"
  }
}
