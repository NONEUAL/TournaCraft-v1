# Province Games Backend — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Database ──────────────────────────────────────────────────
# PostgreSQL connection string
# Local dev:  postgresql://postgres:password@localhost:5432/province_games
# Railway:    Provided automatically as $DATABASE_URL
DATABASE_URL=postgresql://postgres:password@localhost:5432/province_games

# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────
# URL of the frontend (used for CORS allow-list in production).
# Use * to allow all origins in development.
# Example: https://province-games.vercel.app
FRONTEND_URL=*

# ── WebSocket ─────────────────────────────────────────────────
# Set this in the frontend's HTML to point to your backend:
# <script>window.WS_ENDPOINT = 'wss://your-backend.railway.app/ws';</script>
# Or set it here if the frontend is served by this backend in production.
WS_ENDPOINT=ws://localhost:3000/ws
